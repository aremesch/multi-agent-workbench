# Non-interactive pnpm settings.
#
# `confirm-modules-purge=false` lets pnpm rebuild node_modules silently when
# it detects drift from pnpm-lock.yaml (new pnpm major, store-path change,
# etc.). Without this, `pnpm install` in a non-TTY context — every deploy
# script, every CI runner, every Claude Code Bash tool call — dies with
# `ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY` because pnpm tries to
# interactively ask "remove modules dir? (Y/n)" and stdin is piped/closed.
confirm-modules-purge=false
