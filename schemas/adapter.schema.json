{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MAW CLI Adapter Config",
  "description": "Config-driven CLI adapter for a tmux-hosted coding agent. Source of truth for validation is adapter.config.schema.ts (Zod); this file exists only for editor autocomplete on *.jsonc.",
  "type": "object",
  "required": ["kind", "displayName", "spawn", "input"],
  "properties": {
    "$schema": { "type": "string" },
    "kind": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "createWorktree": {
      "type": "boolean",
      "description": "Whether spawning this adapter creates a dedicated git worktree under <worktreeRoot>/<agentId>. Defaults to true. Set false to run directly in the repo root on whatever branch is already checked out (e.g. shell smoke adapter)."
    },
    "acceptsImageAttachment": {
      "type": "boolean",
      "description": "Whether this CLI accepts image attachments via a file path in the prompt body (claude-code, codex, gemini all accept @<path> mentions). When true, MAW renders a paperclip button + paste/drop UI on the agent terminal modal that uploads the image into <worktree>/.maw/uploads/ and types the relative path into the prompt. Defaults to false."
    },
    "mobileQuickKeys": {
      "type": "array",
      "description": "On-screen key-chord buttons rendered under xterm on touch devices. Phone soft keyboards don't expose arrow keys, Esc, Shift+Tab or Ctrl+C — declare the ones this CLI needs here. Empty by default.",
      "items": {
        "type": "object",
        "required": ["id", "label", "keys"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Stable id, unique within this adapter. Lowercase kebab."
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "description": "Short on-button text. Unicode glyphs allowed (e.g. \"↑\", \"⇧⇥\")."
          },
          "keys": {
            "type": "string",
            "minLength": 1,
            "description": "Raw UTF-8 bytes sent via send_keys. Use JSON escapes for control bytes (e.g. \"\\u001b[A\" for cursor up, \"\\u0003\" for Ctrl+C)."
          }
        }
      }
    },
    "spawn": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "optionalArgs": {
          "type": "array",
          "description": "CLI flags the user can toggle on/off per-spawn. Merged at spawn time based on user settings.",
          "items": {
            "type": "object",
            "required": ["id", "flag", "label"],
            "properties": {
              "id": { "type": "string", "minLength": 1, "description": "Stable key used in user settings." },
              "flag": { "type": "string", "minLength": 1, "description": "The actual CLI flag (e.g. --dangerously-skip-permissions)." },
              "label": { "type": "string", "minLength": 1, "description": "Human-readable toggle label." },
              "description": { "type": "string", "description": "Longer explanation shown below the toggle." },
              "default": { "type": "boolean", "description": "Default value when the user has no saved preference." }
            }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "initialInput": {
          "description": "How the task body is delivered to the CLI on spawn. 'none' hides the task-body field in the spawn dialog entirely. 'cli-arg' bakes the substituted template into argv at launch (positional or via a flag).",
          "oneOf": [
            {
              "type": "object",
              "required": ["delivery"],
              "properties": {
                "delivery": { "type": "string", "const": "none" }
              }
            },
            {
              "type": "object",
              "required": ["delivery", "template", "placement"],
              "properties": {
                "delivery": { "type": "string", "const": "cli-arg" },
                "template": { "type": "string", "minLength": 1, "description": "Substituted via {{var}} (typically {{task.body}})." },
                "placement": {
                  "oneOf": [
                    { "type": "string", "const": "positional-last" },
                    {
                      "type": "object",
                      "required": ["flag"],
                      "properties": { "flag": { "type": "string", "minLength": 1 } }
                    }
                  ]
                },
                "omitWhenEmpty": { "type": "boolean", "description": "Skip the extra arg when substituted template is empty. Default true." }
              }
            }
          ]
        }
      }
    },
    "capabilities": {
      "type": "object",
      "description": "Value-bearing CLI selectors exposed in the spawn dialog (model, permission/approval mode, …). The 'arg' template is substituted with {{value}} = the picked option id and appended to argv at spawn.",
      "properties": {
        "model": { "$ref": "#/$defs/capability" },
        "permissionMode": { "$ref": "#/$defs/capability" }
      }
    },
    "input": {
      "type": "object",
      "properties": {
        "encoding": { "type": "string", "enum": ["literal"] },
        "submitKey": { "type": "string" },
        "promptAnswers": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "regex"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["ready", "working", "prompt_detected", "task_done", "error", "exited"]
          },
          "regex": { "type": "string" },
          "flags": { "type": "string" },
          "scope": { "type": "string", "enum": ["tail", "tail_line"] },
          "choices": { "type": "array", "items": { "type": "string" } },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error", "critical"]
          },
          "description": { "type": "string" }
        }
      }
    },
    "idleDetection": {
      "type": "object",
      "properties": {
        "method": { "type": "string", "enum": ["cursor_at_prompt", "inactivity"] },
        "promptLineRegex": { "type": "string" },
        "inactivityMs": { "type": "number" }
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "autoAnswer": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["patternId", "answer"],
            "properties": {
              "patternId": { "type": "string" },
              "when": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "answer": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "required": ["label", "values", "arg"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 }
            }
          }
        },
        "default": { "type": "string", "minLength": 1 },
        "arg": { "type": "string", "minLength": 1, "description": "Substituted template using {{value}} = picked id. Empty result after substitution means 'don't append any arg' (good for a 'default' id)." }
      }
    }
  }
}
