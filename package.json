{
  "name": "multi-agent-workbench",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Alexander Remesch <alexander.remesch@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "UV_THREADPOOL_SIZE=64 vite dev",
    "build": "vite build && node scripts/bundle-server.mjs",
    "preview": "UV_THREADPOOL_SIZE=64 node build/server.js",
    "start": "UV_THREADPOOL_SIZE=64 node build/server.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run --project=server --project=client",
    "test:watch": "vitest --project=server --project=client",
    "test:coverage": "vitest run --project=server --project=client --coverage",
    "test:integration": "vitest run --project=integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:adapter": "tsx scripts/test-adapter.ts",
    "migrate": "tsx scripts/migrate.ts",
    "vapid:gen": "node scripts/generate-vapid-keys.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.1",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^3.0.5",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.0",
    "eslint": "^9.20.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "svelte": "^5.19.6",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^11.8.1",
    "chokidar": "^4.0.3",
    "execa": "^9.5.2",
    "gridstack": "^12.6.0",
    "isomorphic-dompurify": "^3.12.0",
    "jsonc-parser": "^3.3.1",
    "marked": "^18.0.3",
    "playwright": "^1.59.1",
    "strip-ansi": "^7.1.0",
    "ulid": "^2.3.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  }
}
