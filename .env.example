# Multi-Agent Workbench environment

# --- Server ---
PORT=3000
HOST=127.0.0.1

# --- Storage ---
# Where SQLite, push-subscription state, etc. live.
# IMPORTANT: must be on local disk, NOT on NFS (SQLite WAL doesn't work on NFS).
MAW_DATA_DIR=/home/ar/.local/share/maw-dev

# Where named-pipe FIFOs (one per agent) are created. Must be local disk.
MAW_FIFO_DIR=/tmp/maw-fifos

# Where git worktrees for agents will be checked out.
# Can be on NFS in dev (worktrees are just files); recommended local for prod.
MAW_WORKTREE_ROOT=/home/ar/.local/share/maw-dev/worktrees

# --- Auth ---
# Bootstrap password for the single user (only used the first time the DB is empty).
# Change immediately after first login.
MAW_BOOTSTRAP_USERNAME=admin
MAW_BOOTSTRAP_PASSWORD=changeme

# Random bytes for signing session cookies. Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MAW_SESSION_SECRET=replace-me-with-32-bytes-of-base64

# --- Web Push (VAPID) ---
# Generate via:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
MAW_VAPID_PUBLIC_KEY=
MAW_VAPID_PRIVATE_KEY=
MAW_VAPID_SUBJECT=mailto:you@example.com

# --- LLM oversight (optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
