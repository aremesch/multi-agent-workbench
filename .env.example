# Multi-Agent Workbench environment

# --- Server ---
PORT=3000
HOST=127.0.0.1

# --- Reverse proxy / TLS termination ---
# Browser-visible origin (scheme + host + optional port), e.g.
# https://maw.example.com. Required in prod so the WebSocket upgrade
# rejects mismatched `Origin` headers. Leave unset in dev to accept
# any origin (fallback dev behavior).
#
# MUST match the browser's `Origin` header byte-for-byte — the check
# is strict string equality. Specifically:
#   - NO trailing slash   (`https://maw.example.com`, not `.../`)
#   - correct scheme      (`https://` when nginx terminates TLS)
#   - exact host          (`maw.example.com` vs `www.maw.example.com`)
#   - include port only if the browser sees one
# A mismatch closes the WebSocket with code 4403 on every connect,
# producing a reconnect loop and blank terminals in the UI.
# Sanity check in a browser tab on the live URL:
#   console.log(location.origin)   // copy this verbatim
MAW_PUBLIC_ORIGIN=

# Set to 1 when MAW sits behind a reverse proxy (nginx, Caddy,
# Cloudflare Tunnel). Makes clientIp() honor X-Forwarded-For so
# auth.log and the login rate limiter record the real client IP
# instead of the proxy's. Leave unset when MAW is directly exposed.
MAW_TRUST_PROXY=

# --- Storage ---
# Where SQLite, push-subscription state, etc. live.
# IMPORTANT: must be on local disk, NOT on NFS (SQLite WAL doesn't work on NFS).
MAW_DATA_DIR=/home/ar/.local/share/maw-dev

# Where named-pipe FIFOs (one per agent) are created. Must be local disk.
MAW_FIFO_DIR=/tmp/maw-fifos

# Where git worktrees for agents will be checked out.
# Can be on NFS in dev (worktrees are just files); recommended local for prod.
MAW_WORKTREE_ROOT=/home/ar/.local/share/maw-dev/worktrees

# --- Auth ---
# Bootstrap password for the single user (only used the first time the DB is empty).
# Change immediately after first login. The login form uses an email; the
# bootstrap user's email is `<username>@maw.local` (e.g. admin@maw.local).
MAW_BOOTSTRAP_USERNAME=admin
MAW_BOOTSTRAP_PASSWORD=changeme

# Random bytes used by better-auth to sign session cookies. Generate via:
#   openssl rand -base64 32
# (legacy MAW_SESSION_SECRET is also accepted as a fallback for one release).
BETTER_AUTH_SECRET=replace-me-with-32-bytes-of-base64

# Browser-visible URL passed to better-auth as `baseURL`. Optional in dev;
# in prod, set to MAW_PUBLIC_ORIGIN (same value, no trailing slash).
BETTER_AUTH_URL=

# Legacy alias for BETTER_AUTH_SECRET — only consulted when
# BETTER_AUTH_SECRET is unset. Drop after rotating.
MAW_SESSION_SECRET=

# Path override for the auth event log. Defaults to
# ${MAW_DATA_DIR}/auth.log. Keep the default unless you have a reason
# to relocate it; the fail2ban jail under deploy/ expects the real file
# at ${MAW_DATA_DIR}/auth.log (don't use a symlink — pyinotify is
# unreliable with them).
MAW_AUTH_LOG_PATH=

# Login rate limit as count/windowSeconds. Default 10/60 — ten failed
# attempts per 60 seconds per client IP before the login returns 429.
# Counts also feed the fail2ban jail via rate_limited entries.
MAW_LOGIN_RATE_LIMIT=

# --- Web Push (VAPID) ---
# Generate via:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
MAW_VAPID_PUBLIC_KEY=
MAW_VAPID_PRIVATE_KEY=
MAW_VAPID_SUBJECT=mailto:you@example.com

# --- LLM oversight (optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
