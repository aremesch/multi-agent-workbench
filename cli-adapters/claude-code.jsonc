{
  "$schema": "../schemas/adapter.schema.json",
  "kind": "claude-code",
  "displayName": "Claude Code",

  // TUI CLI: repaints its whole UI in the main buffer on every streaming
  // tick, and its Ctrl-O "expand long output" widget produces byte-unequal
  // variants that slip past the repeating-tail dedup. Capture only the
  // currently visible pane on reconnect — tmux scrollback is all ghosts.
  "scrollbackMode": "visible",

  // Pair `visible` mode with the JSONL transcript reader so the reconnect
  // snapshot still surfaces real conversation history (the part that scrolled
  // out of the visible pane) — see docs/plans/v0.1-jsonl-history.md.
  "historySource": { "kind": "claude-jsonl" },

  // Phone soft keyboards hide arrow keys, Esc and Shift+Tab — every one of
  // which Claude Code needs constantly (history recall, menu navigation,
  // plan/thinking tab cycling, dismissing popovers). The user asked for
  // these explicitly; tune as you hit new gaps.
  "mobileQuickKeys": [
    { "id": "up",        "label": "↑",    "keys": "\u001b[A" },
    { "id": "down",      "label": "↓",    "keys": "\u001b[B" },
    { "id": "shift-tab", "label": "⇧⇥",  "keys": "\u001b[Z" },
    { "id": "esc",       "label": "Esc",  "keys": "\u001b"   }
  ],

  // NOTE: these patterns are starting points. Tune against real captured
  // sessions with `pnpm test:adapter cli-adapters/claude-code.jsonc <session.txt>`.
  "spawn": {
    "command": "claude",
    // `--session-id <uuid>` makes the JSONL file path deterministic from
    // spawn time (~/.claude/projects/<encoded-cwd>/<uuid>.jsonl), so the
    // history reader needs no filesystem watch.
    "args": ["--session-id", "{{agent.cliSessionId}}"],
    "optionalArgs": [
      {
        "id": "skip-permissions",
        "flag": "--dangerously-skip-permissions",
        "label": "Skip permission prompts",
        "description": "Agent runs tools without asking. Disable to get push notifications for each tool use.",
        "default": false
      }
    ],
    "env": {
      "ANTHROPIC_API_KEY": "{{env.ANTHROPIC_API_KEY}}"
    },
    "initialInput": "{{task.body}}"
  },

  "input": {
    "encoding": "literal",
    "submitKey": "Enter",
    "promptAnswers": {
      "yes": ["y", "Enter"],
      "no": ["n", "Enter"],
      "1": ["1", "Enter"],
      "2": ["2", "Enter"],
      "abort": ["C-c"]
    }
  },

  "patterns": [
    {
      "id": "plan_approval_prompt",
      "kind": "prompt_detected",
      "regex": "Would you like to proceed\\?",
      "scope": "tail",
      "choices": ["1", "2", "abort"],
      "severity": "warning",
      "description": "Claude Code plan approval prompt"
    },
    {
      "id": "tool_permission_prompt",
      "kind": "prompt_detected",
      "regex": "Do you want to (?:run|proceed with) (?<tool>[a-zA-Z_]+)(?:\\((?<args>[^)]*)\\))?\\?",
      "flags": "m",
      "scope": "tail",
      "choices": ["yes", "no"],
      "severity": "warning",
      "description": "Standard tool-use permission prompt"
    },
    {
      "id": "shell_command_prompt",
      "kind": "prompt_detected",
      "regex": "Run (?<cmd>.+?) \\? \\[y/N\\]",
      "scope": "tail",
      "choices": ["yes", "no"],
      "severity": "warning"
    },
    {
      "id": "ready",
      "kind": "ready",
      "regex": "^>\\s*$",
      "scope": "tail_line"
    },
    {
      "id": "task_done",
      "kind": "task_done",
      "regex": "(?:✓ Task complete|All done!)",
      "scope": "tail",
      "severity": "info"
    },
    {
      "id": "rate_limit",
      "kind": "error",
      "regex": "(?<message>rate.limit|quota exceeded)",
      "flags": "i",
      "scope": "tail",
      "severity": "error"
    }
  ],

  "idleDetection": {
    "method": "cursor_at_prompt",
    "promptLineRegex": "^>\\s*$",
    "inactivityMs": 2000
  },

  "defaults": {
    "autoAnswer": []
  }
}
