{
  "$schema": "../schemas/adapter.schema.json",
  "kind": "claude-code",
  "displayName": "Claude Code",

  // Claude Code accepts image attachments via `@<path>` mentions in the
  // prompt body (5MB max, PNG/JPEG/GIF/WebP). MAW writes pasted/dropped
  // images into <worktree>/.maw/uploads/ and types the relative path
  // into the prompt — see docs/plans/v0.2-image-paste-into-agent.md.
  "acceptsImageAttachment": true,

  // Phone soft keyboards hide arrow keys, Esc and Shift+Tab — every one of
  // which Claude Code needs constantly (history recall, menu navigation,
  // plan/thinking tab cycling, dismissing popovers). The user asked for
  // these explicitly; tune as you hit new gaps.
  "mobileQuickKeys": [
    { "id": "up",        "label": "↑",    "keys": "\u001b[A" },
    { "id": "down",      "label": "↓",    "keys": "\u001b[B" },
    { "id": "shift-tab", "label": "⇧⇥",  "keys": "\u001b[Z" },
    { "id": "esc",       "label": "Esc",  "keys": "\u001b"   }
  ],

  // NOTE: these patterns are starting points. Tune against real captured
  // sessions with `pnpm test:adapter cli-adapters/claude-code.jsonc <session.txt>`.
  "spawn": {
    "command": "claude",
    // `--session-id <uuid>` makes the JSONL transcript path deterministic
    // from spawn time (~/.claude/projects/<encoded-cwd>/<uuid>.jsonl), which
    // is what `summarizeTokenUsage` in ClaudeJsonlTokens.ts reads to surface
    // tokens on the archive page. Presence of {{agent.cliSessionId}} is the
    // signal AgentSupervisor uses to mint and persist the UUID at spawn.
    "args": ["--session-id", "{{agent.cliSessionId}}"],
    "optionalArgs": [
      {
        "id": "skip-permissions",
        "flag": "--dangerously-skip-permissions",
        "label": "Skip permission prompts",
        "description": "Agent runs tools without asking. Disable to get push notifications for each tool use.",
        "default": false
      }
    ],
    "env": {
      "ANTHROPIC_API_KEY": "{{env.ANTHROPIC_API_KEY}}"
    },
    "initialInput": "{{task.body}}"
  },

  "input": {
    "encoding": "literal",
    "submitKey": "Enter",
    "promptAnswers": {
      "yes": ["y", "Enter"],
      "no": ["n", "Enter"],
      "1": ["1", "Enter"],
      "2": ["2", "Enter"],
      "3": ["3", "Enter"],
      "abort": ["C-c"]
    }
  },

  // Patterns tuned against captured Claude Code v2.1.126 panes (May 2026).
  // The hook path (POST /api/internal/claude-hook) is the primary
  // tool-permission detector for claude-code; these regexes are the
  // fallback for agents whose worktree didn't get .claude/settings.local.json
  // and the only path for ready / task_done / error (no hook equivalent).
  "patterns": [
    {
      "id": "plan_approval_prompt",
      "kind": "prompt_detected",
      "regex": "Would you like to proceed\\?",
      "scope": "tail",
      "choices": ["1", "2", "abort"],
      "severity": "warning",
      "description": "Claude Code plan approval prompt"
    },
    {
      "id": "tool_permission_prompt",
      "kind": "prompt_detected",
      // v2.1.x phrasings: `Do you want to create notes.txt?`, `Do you
      // want to make this edit to /abs/file.ts?`, `Do you want to run
      // npm test?`, `Do you want to proceed with foo?`. The action group
      // captures everything between the verb and `?` — alertBody() picks
      // it up in its priority chain (cmd → file_path → args → action).
      // [^?\n]{1,80} caps runaway matches and prevents spanning past `?`.
      "regex": "Do you want to (?<action>[^?\\n]{1,80})\\?",
      "scope": "tail",
      "choices": ["1", "2", "3", "abort"],
      "severity": "warning",
      "description": "Tool-use permission prompt — v2.1.x verbs (create / make this edit to / run / proceed with / etc.)"
    },
    {
      "id": "ready",
      "kind": "ready",
      // The visible footer line: `? for shortcuts` (idle) vs
      // `esc to interrupt` (working). The prompt char `❯` itself is
      // ALWAYS painted in the input box (even mid-task), so it can't
      // gate `ready`; the footer can.
      "regex": "\\? for shortcuts",
      "scope": "tail_line",
      "description": "Footer line shown only while claude is idle / waiting on user"
    },
    {
      "id": "task_done",
      "kind": "task_done",
      // End-of-turn signal: `✻ Cooked for 4s`, `✻ Baked for 9s`,
      // `✻ Sautéed for 12s`, etc. Claude rotates the past-tense verb but
      // always uses ✻ (U+273B). The mid-task spinner uses ✽ (U+273D) and
      // gerund + ellipsis (`✽ Hyperspacing… (7s · …)`) — no `for Ns`,
      // so it doesn't match. The `for \d+[ms]\b` clause is the anchor.
      "regex": "✻ \\S.{0,40}? for \\d+[ms]\\b",
      "scope": "tail",
      "severity": "info",
      "description": "End-of-turn marker (✻ <verb> for <N>[ms])"
    },
    {
      "id": "rate_limit",
      "kind": "error",
      "regex": "(?<message>rate.limit|quota exceeded)",
      "flags": "i",
      "scope": "tail",
      "severity": "error"
    }
  ],

  "idleDetection": {
    "method": "cursor_at_prompt",
    // Same rationale as the `ready` pattern: the footer is the only
    // line whose presence reliably distinguishes idle from working.
    "promptLineRegex": "\\? for shortcuts",
    "inactivityMs": 2000
  },

  "defaults": {
    "autoAnswer": []
  }
}
