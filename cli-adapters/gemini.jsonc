{
  "$schema": "../schemas/adapter.schema.json",
  "kind": "gemini",
  "displayName": "Gemini CLI",

  // Gemini accepts `@<path>` mentions for image attachments — see
  // docs/plans/v0.2-image-paste-into-agent.md.
  "acceptsImageAttachment": true,

  // Agentic coding CLI — eligible for the /queue scheduler.
  "agenticCodingCli": true,

  // Mobile quick-keys for the phone PWA. Starter set — tune against a
  // real gemini session.
  "mobileQuickKeys": [
    { "id": "up",   "label": "↑",   "keys": "\u001b[A" },
    { "id": "down", "label": "↓",   "keys": "\u001b[B" },
    { "id": "tab",  "label": "⇥",   "keys": "\t"       },
    { "id": "esc",  "label": "Esc", "keys": "\u001b"   },
    { "id": "ctrl-c", "label": "^C", "keys": "\u0003"  }
  ],

  // Starter patterns — must be tuned against a real recording.
  "spawn": {
    "command": "gemini",
    "args": [],
    "env": {
      "GEMINI_API_KEY": "{{env.GEMINI_API_KEY}}"
    },
    // Gemini CLI's `--help` shows `gemini [query..]` as the positional —
    // "Initial prompt. Runs in interactive mode by default; use -p/--prompt
    // for non-interactive." So a positional prompt keeps the TUI open.
    "initialInput": {
      "delivery": "cli-arg",
      "template": "{{task.body}}",
      "placement": "positional-last",
      "omitWhenEmpty": true
    }
  },

  // Mirrors claude-code's capability shape. `-m/--model` is the Gemini flag.
  // `--approval-mode` accepts default | auto_edit | yolo | plan (from
  // `gemini --help`).
  "capabilities": {
    "model": {
      "label": "Model",
      "default": "default",
      "arg": "--model {{value}}",
      "values": [
        { "id": "default", "label": "Default" }
      ]
    },
    "permissionMode": {
      "label": "Approval mode",
      "default": "plan",
      "arg": "--approval-mode {{value}}",
      "values": [
        { "id": "plan",      "label": "Plan (read-only)" },
        { "id": "default",   "label": "Default (ask)" },
        { "id": "auto_edit", "label": "Auto-edit" },
        { "id": "yolo",      "label": "YOLO" }
      ]
    }
  },

  "input": {
    "encoding": "literal",
    "submitKey": "Enter",
    "promptAnswers": {
      "yes": ["y", "Enter"],
      "no": ["n", "Enter"],
      "abort": ["C-c"]
    }
  },

  "patterns": [
    {
      "id": "confirm_action",
      "kind": "prompt_detected",
      "regex": "Confirm (?<action>.+?) \\[Y/n\\]",
      "scope": "tail",
      "choices": ["yes", "no"],
      "severity": "warning"
    },
    {
      "id": "ready",
      "kind": "ready",
      "regex": "^gemini>\\s*$",
      "scope": "tail_line"
    },
    {
      "id": "task_done",
      "kind": "task_done",
      "regex": "Completed successfully",
      "scope": "tail"
    }
  ],

  "idleDetection": {
    "method": "cursor_at_prompt",
    "promptLineRegex": "^gemini>\\s*$",
    "inactivityMs": 2000
  },

  "defaults": {
    "autoAnswer": []
  }
}
