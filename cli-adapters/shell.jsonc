{
  "$schema": "../schemas/adapter.schema.json",
  "kind": "shell",
  "displayName": "bash",

  // Run directly in the repo root on whatever branch is already checked
  // out — no disposable `maw/<agentId>` worktree. The smoke adapter is a
  // plain bash shell; a throwaway side branch would be noise.
  "createWorktree": false,

  // Mobile quick-keys for bare bash: readline history + completion, Esc
  // for vim-mode escapes, Ctrl+C for SIGINT. These are the keys a phone
  // keyboard cannot produce.
  "mobileQuickKeys": [
    { "id": "up",     "label": "↑",   "keys": "\u001b[A" },
    { "id": "down",   "label": "↓",   "keys": "\u001b[B" },
    { "id": "tab",    "label": "⇥",   "keys": "\t"       },
    { "id": "esc",    "label": "Esc", "keys": "\u001b"   },
    { "id": "ctrl-c", "label": "^C",  "keys": "\u0003"   }
  ],

  // Minimal adapter with no pattern matching — exists only to exercise the
  // tmux + FIFO + WebSocket pipeline end-to-end without depending on any
  // third-party CLI being installed. No prompts, no task interpolation.
  "spawn": {
    "command": "bash",
    "args": ["-i"],
    "env": {}
  },

  "input": {
    "encoding": "literal",
    "submitKey": "Enter",
    "promptAnswers": {}
  },

  "patterns": [],

  "idleDetection": {
    "method": "inactivity",
    "inactivityMs": 2000
  },

  "defaults": {
    "autoAnswer": []
  }
}
