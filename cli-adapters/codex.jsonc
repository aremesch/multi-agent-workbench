{
  "$schema": "../schemas/adapter.schema.json",
  "kind": "codex",
  "displayName": "Codex CLI",

  // Codex accepts `@<path>` mentions for image attachments — see
  // docs/plans/v0.2-image-paste-into-agent.md.
  "acceptsImageAttachment": true,

  // Mobile quick-keys for the phone PWA. Starter set — same rationale as
  // claude-code.jsonc. Tune against a real codex session.
  "mobileQuickKeys": [
    { "id": "up",   "label": "↑",   "keys": "\u001b[A" },
    { "id": "down", "label": "↓",   "keys": "\u001b[B" },
    { "id": "tab",  "label": "⇥",   "keys": "\t"       },
    { "id": "esc",  "label": "Esc", "keys": "\u001b"   },
    { "id": "ctrl-c", "label": "^C", "keys": "\u0003"  }
  ],

  // Starter patterns — must be tuned against a real recording.
  "spawn": {
    "command": "codex",
    "args": [],
    "env": {
      "OPENAI_API_KEY": "{{env.OPENAI_API_KEY}}"
    },
    // TODO(verify): Codex CLI's positional-prompt support has not been
    // verified against a real install. Until someone confirms `codex
    // "<prompt>"` keeps the TUI interactive (and doesn't exit non-
    // interactive like `-p` would), keep delivery = 'none' so the spawn
    // dialog hides the task-body textarea for this adapter. Flip to
    // 'cli-arg' / 'positional-last' once verified.
    "initialInput": { "delivery": "none" }
  },

  "input": {
    "encoding": "literal",
    "submitKey": "Enter",
    "promptAnswers": {
      "yes": ["y", "Enter"],
      "no": ["n", "Enter"],
      "abort": ["C-c"]
    }
  },

  "patterns": [
    {
      "id": "approval_prompt",
      "kind": "prompt_detected",
      "regex": "Approve (?<action>.+?)\\? \\[y/N\\]",
      "scope": "tail",
      "choices": ["yes", "no"],
      "severity": "warning"
    },
    {
      "id": "ready",
      "kind": "ready",
      "regex": "^codex>\\s*$",
      "scope": "tail_line"
    },
    {
      "id": "task_done",
      "kind": "task_done",
      "regex": "^Done\\.?\\s*$",
      "flags": "m",
      "scope": "tail"
    }
  ],

  "idleDetection": {
    "method": "cursor_at_prompt",
    "promptLineRegex": "^codex>\\s*$",
    "inactivityMs": 2000
  },

  "defaults": {
    "autoAnswer": []
  }
}
